<Window x:Class="OptimizationAPP.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OptimizationAPP"
        mc:Ignorable="d"
        Title="SYS_OPTIMIZER" Height="520" Width="860" ResizeMode="CanMinimize" Background="#0D0D0D">
      
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
       
        <Border Grid.Column="0" Background="#0A0A0F" BorderBrush="#00A8A8" BorderThickness="0,0,1,0">
            <DockPanel>
                <Border DockPanel.Dock="Top" BorderBrush="#008080" BorderThickness="0,0,0,1" Padding="14,12">
                    <TextBlock Text="// SYS_MODULES" FontSize="11" FontFamily="Courier New" Foreground="#00FFFF"/>
                </Border>
                
                <Border DockPanel.Dock="Bottom" BorderThickness="0,1,0,0" BorderBrush="#008080" Padding="10,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="btnEsp" Grid.Column="0" Content="[ ES-MX ]" FontFamily="Courier New" FontSize="11" Cursor="Hand" Click="btnEsp_Click" Style="{StaticResource BtnIdioma}"/>
                        <Button x:Name="btnEng" Grid.Column="1" Content="[ EN-USA ]" FontFamily="Courier New" FontSize="11" Cursor="Hand" Click="btnEng_Click" Style="{StaticResource BtnIdioma}"/>
                    </Grid>
                </Border>

                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <Button x:Name="btnStart" Content="> HOME" Style="{StaticResource BtnSidebar}" Height="60" Click="btnStart_Click" />
                        <Button x:Name="btnTempFiles" Content="> TEMP_FILES" Style="{StaticResource BtnSidebar}" Height="44" Click="btnTemp_Click"/>
                        <Button x:Name="btnBasicDisk" Content="> DISK" Style="{StaticResource BtnSidebar}" Height="44" Click="btnDisk_Click"/>
                        <Button x:Name="btnNvidiaSettings" Content="> NVIDIA_SETTINGS" Style="{StaticResource BtnSidebar}" Height="44" Click="btnNvidia_Click"/>

                        <Border BorderBrush="#800080" BorderThickness="0,1,0,0" Margin="10,4,10,4"/>
                        <Button x:Name="btnDeepTempFiles" Content="> MORE_TEMP_FILES" Style="{StaticResource BtnSidebar}" Height="44" ToolTipService.ShowOnDisabled="True" Click="btnDeepTemp_Click"/>
                        <Button x:Name="btnPrefetch" Content="> PREFETCH" Style="{StaticResource BtnSidebar}" Height="44" ToolTipService.ShowOnDisabled="True" Click="btnPrefetch_Click"/>
                        <Button x:Name="btnEventViewer" Content="> EVENT_VIEWER" Style="{StaticResource BtnSidebar}" Height="44" ToolTipService.ShowOnDisabled="True" Click="btnEvent_Click"/>
                        <Button x:Name="btnAdvancedDisk" Content="> ADVANCED_DISK" Style="{StaticResource BtnSidebar}" Height="44" ToolTipService.ShowOnDisabled="True" Click="btnAdvDisk_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <Frame Name="menuFrame" NavigationUIVisibility="Hidden" Grid.Column="1"/>
    </Grid>
</Window>
