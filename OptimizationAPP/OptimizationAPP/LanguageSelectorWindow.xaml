<Window x:Class="OptimizationAPP.LanguageSelectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OptimizationAPP"
        mc:Ignorable="d"
        Title="SYS_OPTIMIZER" Height="230" Width="430" ResizeMode="NoResize" WindowStartupLocation="CenterScreen" Background="#0D0D0D">
    <Grid>
        <Border HorizontalAlignment="Left" VerticalAlignment="Top" Width="18" Height="18" Margin="10" BorderBrush="{StaticResource CyanBrush}" 
            BorderThickness="1,1,0,0" Opacity="0.5"/>
        <Border HorizontalAlignment="Left" VerticalAlignment="Bottom" Width="18" Height="18" Margin="10" BorderBrush="{StaticResource CyanBrush}" 
            BorderThickness="1,0,0,1" Opacity="0.5"/>
        <Border HorizontalAlignment="Right" VerticalAlignment="Top" Width="18" Height="18" Margin="10" BorderBrush="{StaticResource CyanBrush}" 
            BorderThickness="0,1,1,0" Opacity="0.5"/>
        <Border HorizontalAlignment="Right" VerticalAlignment="Bottom" Width="18" Height="18" Margin="10" BorderBrush="{StaticResource CyanBrush}" 
            BorderThickness="0,0,1,1" Opacity="0.5"/>

        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="// SYSTEM_INIT" FontFamily="Courier New" FontSize="11" Foreground="{StaticResource MagentaBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
            <TextBlock Text="SYS_OPTIMIZER" FontFamily="Courier New" FontSize="32" FontWeight="Bold" Foreground="{StaticResource CyanBrush}" HorizontalAlignment="Center" Margin="0,0,0,6"/>

            <Rectangle Height="1" Width="300" Margin="0,0,0,24">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="Transparent" Offset="0"/>
                        <GradientStop Color="#00FFFF" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="0.5"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
            
            <TextBlock Text="SELECCIONA IDIOMA / SELECT LANGUAGE" FontFamily="Courier New"
                       FontSize="11" Foreground="#9E9E9E" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="btnSpanish" Content="[ ESPAÑOL ] " Style="{StaticResource BtnPrimary}" Width="160" Height="40" Margin="0,0,16,0" Click="btnSpanish_Click"/>
                <Button x:Name="btnEnglish" Content="[ ENGLISH ]" Style="{StaticResource BtnEn}" Width="160" Height="40" Click="btnEnglish_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
