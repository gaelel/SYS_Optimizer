<Page x:Class="OptimizationAPP.Pages.DeepTempPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:OptimizationAPP.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="DeepTempPage">

    <ScrollViewer Grid.Row="0" Grid.Column="0" VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="10">
        <TextBlock Text="Deep Temp File Clean-up" FontSize="25"/>
        <TextBlock Text="Descripción del módulo..." TextWrapping="Wrap"/>
        <Button Content="Iniciar limpieza"/>
        </StackPanel>
    </ScrollViewer>
</Page>
